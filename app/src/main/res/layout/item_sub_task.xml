<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:id="@+id/oblProject"
    android:layout_height="90dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="20dp"
    android:layout_marginStart="30dp"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="20dp"
    android:background="@drawable/shape_dialog_background">

    <TextView
        android:id="@+id/tvTaskName"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Project name"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:fontFamily="@font/nunito_semibold"
        android:layout_marginVertical="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginStart="212dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/shape_rounded_variants"
        android:backgroundTint="@color/firstDarkColor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginStart="212dp"
        android:layout_marginTop="8dp"
        android:visibility="invisible"
        android:background="@drawable/shape_rounded_variants"
        android:src="@drawable/ic_galka"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="68dp"
        android:layout_height="49dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Меню"/>

    <Button
        android:id="@+id/btnArchive"
        android:layout_width="110dp"
        android:layout_height="40dp"
        android:text="Архивировать"
        android:layout_marginVertical="130dp"
        android:layout_marginStart="200dp"
        android:padding="0dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/secondGreen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:visibility="gone"
        />

</androidx.constraintlayout.widget.ConstraintLayout>