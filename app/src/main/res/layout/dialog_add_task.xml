<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_marginStart="30dp"
    android:layout_marginVertical="30dp"
    android:background="@drawable/shape_dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Форма для создания Задачи"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:fontFamily="@font/rubik_regular"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <EditText
        android:id="@+id/etTaskName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="30dp"
        android:hint="Название"
        android:textColorHint="@color/black"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <EditText
        android:id="@+id/etDestination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Описание"
        android:textColorHint="@color/black"
        android:layout_marginVertical="80dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <EditText
        android:id="@+id/etPercent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="10"
        android:textColorHint="@color/black"
        android:layout_marginVertical="130dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <EditText
        android:id="@+id/etDiff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Hard"
        android:textColorHint="@color/black"
        android:layout_marginVertical="170dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <Button
        android:id="@+id/btnSave"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:text="Сохранить"
        android:padding="0dp"
        android:layout_marginVertical="230dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/green"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <Button
        android:id="@+id/btnDelete"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:text="Удалить"
        android:padding="0dp"
        android:layout_marginVertical="230dp"
        android:layout_marginStart="110dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/red"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />
    <Button
        android:id="@+id/btnArchive"
        android:layout_width="110dp"
        android:layout_height="40dp"
        android:text="Архивировать"
        android:layout_marginVertical="230dp"
        android:layout_marginStart="200dp"
        android:padding="0dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/orange"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>