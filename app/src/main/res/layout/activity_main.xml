<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/firstGreen"
    tools:context=".ControllerActivity.MainActivity"
    tools:layout_editor_absoluteX="0dp"
    tools:layout_editor_absoluteY="14dp">

    <!-- 1. Верхняя тонкая полоска -->
    <View
        android:id="@+id/toolbar2"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="@color/firstDarkColor"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Основная шапка (Убрал backgroundTint, добавил правильную верстку внутри) -->
    <Toolbar
        android:id="@+id/toolbar1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/threeGreen"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2">

        <TextView
            android:id="@+id/tvTaskVault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/minecraft"
            android:text="TaskVault"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:contentDescription="Menu"
            android:layout_gravity="end"
            android:src="@drawable/ic_bar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </Toolbar>

    <!-- 3. Список задач (RecyclerView теперь привязан строго под шапку) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recV"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar1"
        tools:itemCount="0"
        tools:listitem="@null" />

    <!-- 4. Кнопка + (backgroundTint тоже берется из темы) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn1Create"
        android:layout_width="65dp"
        android:layout_height="65dp"
        app:fabCustomSize="65dp"
        app:maxImageSize="43dp"
        android:src="@drawable/ic_add"
        android:scaleType="center"
        android:backgroundTint="@color/fourGreen"
        android:layout_marginBottom="50dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>