<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fon"
    tools:context=".ControllerActivity.OneTaskActivity"
    tools:layout_editor_absoluteX="0dp"
    tools:layout_editor_absoluteY="14dp">

    <Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="@color/green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" >

    </Toolbar>

    <Toolbar
        android:id="@+id/toolbar1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar2"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/tvTaskVault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/minecraft"
            android:text="TaskVault"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:layout_gravity="start"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.052"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/toolbar1"
            app:layout_constraintVertical_bias="0.023" />

        <ImageButton
            android:layout_width="68dp"
            android:layout_height="49dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_bar"
            android:layout_gravity="end"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1"
            app:layout_constraintStart_toStartOf="@id/tvTaskVault"
            app:layout_constraintTop_toTopOf="@+id/toolbar1"
            app:layout_constraintVertical_bias="0.001" />

    </Toolbar>

    <TextView
        android:layout_width="191dp"
        android:layout_height="35dp"
        android:background="@drawable/shape_rounded_tv"
        android:text="Добро пожаловать"
        android:fontFamily="@font/nunito_semibold"
        android:textSize="18sp"
        android:gravity="center"
        android:textColor="@color/black"
        android:typeface="serif"
        android:shadowColor="@color/white"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="10"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.205"/>

    <EditText android:layout_width="250dp"
        android:layout_height="40dp"
        android:hint="Введите своё имя"
        android:gravity="center"
        android:textColor="@color/black"
        android:textColorHint="@color/grey"
        android:backgroundTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.373"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn1Transit"
        android:layout_width="120dp"
        android:layout_height="50dp"
        android:text="Начать!"
        android:textSize="18dp"
        android:fontFamily="@font/minecraft"
        android:textColor="@color/black"
        android:backgroundTint="@color/lightOrange"
        android:padding="0dp"
        android:shadowDx="12"
        android:shadowDy="12"
        android:shadowRadius="30"
        app:cornerRadius="10dp"
        app:strokeColor="@color/darkOrange"
        app:strokeWidth="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>